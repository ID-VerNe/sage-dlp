{
  "name": "SageDLP Cookie Bridge",
  "description": "Auto-sends cookies to SageDLP via localhost:9876 (forked from Get cookies.txt LOCALLY)",
  "version": "0.7.3",
  "manifest_version": 3,
  "permissions": ["activeTab", "cookies", "downloads", "notifications"],
  "host_permissions": ["<all_urls>", "http://127.0.0.1:9876/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "/images/icon16.png",
      "32": "/images/icon32.png",
      "48": "/images/icon48.png",
      "128": "/images/icon128.png"
    }
  },
  "icons": {
    "16": "/images/icon16.png",
    "32": "/images/icon32.png",
    "48": "/images/icon48.png",
    "128": "/images/icon128.png"
  },
  "incognito": "split",
  "background": {
    "service_worker": "background.mjs",
    "type": "module"
  }
}
